{
  // Zed settings
  //
  // For information on how to configure Zed, see the Zed//zed.dev/docs/configuring-zed
  //
  // To see all of Zed's default settings without changing your
  // custom settings, run `zed: open default settings` from the
  // command palette (cmd-shift-p / ctrl-shift-p)
  "language_models": {
    "openai_compatible": {
      
    }
  },
  "agent_servers": {
    },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "google",
      "model": "gemini-2.5-flash-lite",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "theme": {
    "mode": "system",
    "light": "Vercel Light",
    "dark": "Vercel Dark",
  },
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 14.0,
  "buffer_font_family": "SF Mono",
  "buffer_font_size": 13.0,
  "session": {
    "trust_all_worktrees": true,
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
}
